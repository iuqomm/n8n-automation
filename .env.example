# Copiar este archivo como .env y completar los valores antes de correr docker compose

# Contraseña de PostgreSQL (cambiar esto)
POSTGRES_PASSWORD=tu_password_segura_aqui

# IP o hostname del servidor en la red local (dejar vacío para usar localhost)
N8N_HOST=
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/

# ID del Google Spreadsheet (está en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit)
SPREADSHEET_ID=

# ─────────────────────────────────────────────────────────────
# CREDENCIALES — configurar manualmente en n8n tras importar el workflow
# ─────────────────────────────────────────────────────────────
# 1. Google Sheets OAuth2 API
#    - Crear proyecto en console.cloud.google.com
#    - Habilitar Google Sheets API y Google Drive API
#    - Crear credencial OAuth2 (Web app) con redirect URI:
#      http://localhost:5678/rest/oauth2-credential/callback
#
# 2. Groq API
#    - Crear cuenta en console.groq.com (gratis)
#    - Generar API Key y cargarla en n8n como credencial "Groq"
